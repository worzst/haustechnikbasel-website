---
const steps = [
  { n: '01', title: 'Anfrage', desc: 'Formular oder Anruf, erzählen Sie uns, was Sie planen.' },
  { n: '02', title: 'Rückruf', desc: 'Innerhalb von 24 Stunden mit einer ehrlichen Ersteinschätzung.' },
  { n: '03', title: 'Vor-Ort-Termin', desc: 'Aufnahme, Beratung, Massnehmen. Kostenlos und unverbindlich.' },
  { n: '04', title: 'Fix-Offerte', desc: 'Detailliert, mit Terminplan und Kostenrahmen. Innerhalb von 7 Tagen.' },
  { n: '05', title: 'Umsetzung', desc: 'Saubere Bauleitung vom ersten Hammer bis zur gemeinsamen Schlussabnahme.' },
];
---
<section id="prozess" class="process-section">
  <div class="process-inner">
    <span class="section-label">02 — Ablauf</span>
    <h2 class="title">So läuft Ihr Badumbau ab. <span>Fünf Schritte.</span></h2>

    <div class="progress-wrap" style="margin-top:56px;">
      <div class="progress-bar">
        <div class="progress-fill" id="progress-fill" style="width:20%"></div>
        <div class="progress-dots" id="progress-dots">
          {steps.map((_, i) => (
            <div class:list={['progress-dot', { done: i === 0 }]}
                 style={i === 0 ? 'justify-self:start' : i === 4 ? 'justify-self:end' : ''} />
          ))}
        </div>
      </div>
    </div>

    <div class="steps" id="process-steps">
      {steps.map((s, i) => (
        <div class:list={['step-card', { active: i === 0 }]} data-idx={i}>
          <div class="step-num">{s.n}</div>
          <div class="step-title">{s.title}</div>
          <p class="step-desc">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section { padding: 96px 48px; background: var(--bg); }
  .process-inner { max-width: 1440px; margin: 0 auto; }

  .title {
    font-size: 48px; font-weight: 600;
    letter-spacing: -0.025em; line-height: 1.02;
    color: var(--ink); margin: 0 0 4px;
  }
  .title span { color: var(--ink-3); }

  .progress-bar {
    position: relative; height: 4px;
    background: var(--line); border-radius: 2px;
  }
  .progress-fill {
    height: 100%; background: var(--blue);
    border-radius: 2px; transition: width 0.5s ease;
  }
  .progress-dots {
    display: grid; grid-template-columns: repeat(5, 1fr);
    position: absolute; top: -8px; left: 0; right: 0;
  }
  .progress-dot {
    width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid var(--line); background: var(--bg);
    transition: all 0.4s; justify-self: center;
  }
  .progress-dot:first-child { justify-self: start; }
  .progress-dot:last-child { justify-self: end; }
  .progress-dot.done { background: var(--blue); border-color: var(--blue); }

  .steps {
    display: grid; grid-template-columns: repeat(5, 1fr);
    gap: 16px; margin-top: 56px;
  }

  .step-card {
    padding: 24px;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background: var(--bg-white);
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .step-card.active {
    background: var(--blue); border-color: var(--blue); color: #fff;
    transform: translateY(-4px);
    box-shadow: 0 20px 60px -20px rgba(30,58,138,0.4);
  }
  .step-num {
    font-family: var(--mono); font-size: 11px;
    color: var(--ink-3); margin-bottom: 14px;
  }
  .step-card.active .step-num { color: rgba(255,255,255,0.6); }
  .step-title {
    font-size: 18px; font-weight: 600;
    letter-spacing: -0.01em; margin-bottom: 8px; color: var(--ink);
  }
  .step-card.active .step-title { color: #fff; }
  .step-desc {
    font-size: 13px; line-height: 1.55; color: var(--ink-2); margin: 0;
  }
  .step-card.active .step-desc { color: rgba(255,255,255,0.75); }

  @media (max-width: 900px) {
    .steps { grid-template-columns: 1fr 1fr; }
    .title { font-size: 36px; }
  }
  @media (max-width: 600px) {
    .process-section { padding: 72px 20px; }
    .steps { grid-template-columns: 1fr; }
    .progress-dots { display: none; }
  }
</style>

<script>
  const steps = document.querySelectorAll('#process-steps .step-card');
  const dots = document.querySelectorAll('#progress-dots .progress-dot');
  const fill = document.getElementById('progress-fill');
  let activeStep = 0;

  function activateStep(i: number) {
    steps.forEach((s, idx) => s.classList.toggle('active', idx === i));
    dots.forEach((d, idx) => d.classList.toggle('done', idx <= i));
    if (fill) fill.style.width = ((i + 1) / 5 * 100) + '%';
    activeStep = i;
  }

  steps.forEach((s, i) => {
    s.addEventListener('click', () => {
      clearInterval(timer);
      activateStep(i);
    });
  });

  const timer = setInterval(() => {
    activateStep((activeStep + 1) % 5);
  }, 2200);
</script>
