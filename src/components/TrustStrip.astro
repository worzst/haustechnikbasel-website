---
const items = [
  {
    label: 'Lokaler Fachbetrieb',
    sub: 'In Basel und Umgebung verwurzelt',
    icon: '<circle cx="10" cy="10" r="8" stroke="var(--blue)" stroke-width="1.5"/><path d="M7 10l2.5 2.5 4-5" stroke="var(--blue)" stroke-width="1.5"/>',
  },
  {
    label: 'Persönlicher Kontakt',
    sub: 'Von Planung bis Fertigstellung',
    icon: '<path d="M10 2l1.5 4.5H17l-4 3 1.5 4.5L10 11l-4.5 3L7 9.5 3 6.5h5.5z" stroke="var(--blue)" stroke-width="1.5"/>',
  },
  {
    label: 'Transparente Offerten',
    sub: 'Keine versteckten Kosten',
    icon: '<rect x="3" y="5" width="14" height="12" rx="1" stroke="var(--blue)" stroke-width="1.5"/><path d="M7 5V4a3 3 0 0 1 6 0v1" stroke="var(--blue)" stroke-width="1.5"/>',
  },
  {
    label: 'Flexible Termine',
    sub: 'Nach Ihren Arbeitszeiten möglich',
    icon: '<circle cx="10" cy="10" r="8" stroke="var(--blue)" stroke-width="1.5"/><path d="M10 6v4l3 2" stroke="var(--blue)" stroke-width="1.5"/>',
  },
  {
    label: '4.9 / 5 Bewertung',
    sub: '47 Google-Rezensionen',
    icon: '<path d="M10 3L12 8h5l-4 3 1.5 5L10 13l-4.5 3L7 11 3 8h5z" stroke="var(--blue)" stroke-width="1.5"/>',
  },
];
---
<div class="trust-strip">
  {items.map(item => (
    <div class="trust-item">
      <div class="trust-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" set:html={item.icon} />
      </div>
      <div>
        <div class="trust-label">{item.label}</div>
        <div class="trust-sub">{item.sub}</div>
      </div>
    </div>
  ))}
</div>

<style>
  .trust-strip {
    background: var(--bg-white);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 32px 48px;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
    max-width: 100%;
  }

  .trust-item {
    display: flex; align-items: flex-start; gap: 14px;
  }

  .trust-icon {
    width: 40px; height: 40px;
    background: var(--blue-bg);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .trust-label {
    font-size: 14px; font-weight: 600;
    letter-spacing: -0.01em; margin-bottom: 2px;
    color: var(--ink);
  }
  .trust-sub { font-size: 12px; color: var(--ink-2); line-height: 1.4; }

  @media (max-width: 1024px) {
    .trust-strip { grid-template-columns: repeat(3, 1fr); padding: 28px 24px; }
  }
  @media (max-width: 600px) {
    .trust-strip { grid-template-columns: 1fr 1fr; padding: 24px 20px; gap: 20px; }
  }
</style>
