---
const features = [
  { n: '01 / 06', title: 'Im Zeitrahmen', desc: 'Fixer Start- und Endtermin. Wir kommunizieren proaktiv, falls etwas abweicht.' },
  { n: '02 / 06', title: 'Ein Ansprechpartner', desc: 'Sie reden mit uns. Wir koordinieren Sanitär, Plattenleger, Elektriker, Maler.' },
  { n: '03 / 06', title: 'Fix-Offerte', desc: 'Pauschal, transparent, ohne Nachschüsse — solange der Auftragsumfang stabil bleibt.' },
  { n: '04 / 06', title: 'Saubere Baustelle', desc: 'Staubschutz, abgeklebte Wege, tägliche Reinigung. Sie bewohnen weiter Ihre Wohnung.' },
  { n: '05 / 06', title: 'Material-Beratung', desc: 'Armaturen, Fliesen, Sanitärobjekte — auf Wunsch begleiten wir den Showroom-Termin.' },
  { n: '06 / 06', title: 'Komplette Koordination', desc: 'Termine, Lieferungen, Abnahmen. Sie müssen sich um nichts kümmern.' },
];
---
<section id="leistungen" class="features-section">
  <div class="features-inner">
    <div class="head">
      <div>
        <span class="section-label">01 — Leistung</span>
        <h2 class="title">Was Sie konkret bekommen.</h2>
      </div>
      <p class="head-sub">Kein Technik-Gefasel. Sechs Punkte, die für Ihr Projekt wirklich zählen.</p>
    </div>

    <div class="grid reveal">
      {features.map(f => (
        <div class="cell">
          <div class="cell-num">{f.n}</div>
          <div class="cell-title">{f.title}</div>
          <p class="cell-desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 96px 48px;
    background: var(--bg-white);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .features-inner { max-width: 1440px; margin: 0 auto; }

  .head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 48px; flex-wrap: wrap; gap: 24px;
  }
  .title {
    font-size: 48px; font-weight: 600;
    letter-spacing: -0.025em; line-height: 1.02;
    color: var(--ink); margin: 0;
  }
  .head-sub {
    font-size: 14px; color: var(--ink-2); max-width: 320px; line-height: 1.6; margin: 0;
  }

  .grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0;
    border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden;
  }

  .cell {
    padding: 28px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--bg-white);
  }
  .cell:nth-child(3n) { border-right: none; }
  .cell:nth-child(4), .cell:nth-child(5), .cell:nth-child(6) { border-bottom: none; }

  .cell-num {
    font-family: var(--mono); font-size: 11px;
    color: var(--ink-3); margin-bottom: 12px;
  }
  .cell-title {
    font-size: 18px; font-weight: 600;
    letter-spacing: -0.01em; margin-bottom: 8px; color: var(--ink);
  }
  .cell-desc {
    font-size: 14px; color: var(--ink-2); line-height: 1.55; margin: 0;
  }

  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr; }
    .cell { border-right: 1px solid var(--line) !important; border-bottom: 1px solid var(--line) !important; }
    .cell:nth-child(2n) { border-right: none !important; }
    .cell:nth-child(5), .cell:nth-child(6) { border-bottom: none !important; }
  }
  @media (max-width: 600px) {
    .features-section { padding: 72px 20px; }
    .title { font-size: 36px; }
    .grid { grid-template-columns: 1fr; }
    .cell { border-right: none !important; }
    .cell:last-child { border-bottom: none !important; }
  }
</style>
