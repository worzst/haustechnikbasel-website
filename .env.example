# ──────────────────────────────────────────────
# Astro build-time (copy to .env for local dev)
# ──────────────────────────────────────────────

# Google Tag Manager container ID
PUBLIC_GTM_ID=GTM-XXXXXXX

# ──────────────────────────────────────────────
# Cloudflare Pages Function runtime
# (copy to .dev.vars for local dev with wrangler)
# ──────────────────────────────────────────────

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Contact form recipient
CONTACT_TO=info@haustechnikbasel.ch

# Contact form sender — must be a verified domain in Resend
CONTACT_FROM=forms@haustechnikbasel.ch

# BCC on every contact form submission (optional — leave empty to disable)
CONTACT_BCC=
